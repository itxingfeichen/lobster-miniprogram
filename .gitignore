# 依赖
node_modules/
package-lock.json
yarn.lock

# 编译输出
dist/
unpackage/

# 开发工具
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境配置
.env.local
.env.*.local

# 小程序配置（敏感信息）
project.config.json
project.private.config.json

# 临时文件
*.tmp
*.temp
.cache/

# 截图和调试文件（不追踪根目录下的图片）
*.jpg
*.jpeg
*.gif

# 允许 static 目录下的图片资源
!static/images/**
!static/icons/**
